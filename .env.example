# ============================================================
# BadmintonHub — Environment Template
# Copy this file to .env and fill in your real values.
# This file IS safe to commit (no real secrets).
# ============================================================

# ===========================
# INFRASTRUCTURE — defaults match docker-compose.yml
# ===========================
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

DB_USER_URL=jdbc:postgresql://localhost:5441/user_db
DB_COURT_URL=jdbc:postgresql://localhost:5433/court_db
DB_BOOKING_URL=jdbc:postgresql://localhost:5434/booking_db
DB_MATCHMAKING_URL=jdbc:postgresql://localhost:5435/matchmaking_db
DB_PAYMENT_URL=jdbc:postgresql://localhost:5436/payment_db
DB_ESCROW_URL=jdbc:postgresql://localhost:5437/escrow_db
DB_COACH_URL=jdbc:postgresql://localhost:5438/coach_db
DB_EVENT_URL=jdbc:postgresql://localhost:5439/event_db

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

MONGODB_URI=mongodb://localhost:27017/notification_db

ELASTICSEARCH_URIS=http://localhost:9200

ZIPKIN_URL=http://localhost:9411/api/v2/spans

EUREKA_URL=http://localhost:8761/eureka/

# ===========================
# APP TUNABLES — hold / expiry windows (minutes)
# Keep PAYMENT_EXPIRE_MINUTES == BOOKING_HOLD_MINUTES so a booking hold and its
# payment countdown expire together. Lower to 1 for fast end-to-end testing.
# ===========================
BOOKING_HOLD_MINUTES=15
PAYMENT_EXPIRE_MINUTES=15

# ===========================
# JWT — HS256
# Generate: openssl rand -hex 64
# ===========================
JWT_SECRET=FILL_IN
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=2592000000

# ===========================
# GOOGLE OAUTH2
# https://console.cloud.google.com → APIs & Services → Credentials
# ===========================
GOOGLE_CLIENT_ID=FILL_IN
GOOGLE_CLIENT_SECRET=FILL_IN

# ===========================
# SENDGRID
# https://app.sendgrid.com/settings/api_keys
# ===========================
SENDGRID_API_KEY=FILL_IN
SENDGRID_FROM_EMAIL=noreply@badmintonhub.vn
SENDGRID_FROM_NAME=BadmintonHub

# ===========================
# FRONTEND (base URL for email links — verify email / reset password)
# ===========================
FRONTEND_URL=http://localhost:5173

# ===========================
# CLOUDINARY
# https://console.cloudinary.com/settings/api-keys
# ===========================
CLOUDINARY_CLOUD_NAME=FILL_IN
CLOUDINARY_API_KEY=FILL_IN
CLOUDINARY_API_SECRET=FILL_IN

# ===========================
# AI SERVICE (OpenAI)
# https://platform.openai.com/api-keys
# ===========================
OPENAI_API_KEY=FILL_IN

# ===========================
# FCM (Firebase Cloud Messaging)
# https://console.firebase.google.com → Project Settings → Service accounts
# ===========================
FCM_SERVER_KEY=FILL_IN
